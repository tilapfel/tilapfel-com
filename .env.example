# Netlify Blobs (used by netlify/functions/form-token.mjs and form-submit.mjs
# for spam protection) authenticates automatically at runtime via the Netlify
# environment — no manual credentials needed, locally or in production.
#
# The three vars below tune the spam-protection thresholds in
# netlify/functions/form-submit.mjs. They aren't secrets in the API-key
# sense, but the repo is public, so the *real* operating values live only in
# the Netlify dashboard (Site settings -> Environment variables) — set them
# to something other than the in-code fallback defaults, so the exact
# thresholds a spammer would need to slip under aren't visible in the repo.
SPAM_MIN_FILL_SECONDS=
SPAM_RATE_LIMIT_WINDOW_MS=
SPAM_RATE_LIMIT_MAX=

# GitHub OAuth App backing the /admin content dashboard (see README.md ->
# "Admin-Dashboard"). Real secret values — never commit them. Create the
# OAuth App at github.com/settings/developers, callback URL
# <netlify-url>/api/callback, then set these two in the Netlify dashboard.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# If a future feature needs a secret (e.g. an API key for a real newsletter
# provider), add it here as NAME=, then set the real value only in the
# Netlify dashboard under Site settings -> Environment variables. Never commit
# real secret values to this repo.
